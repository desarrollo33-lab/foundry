---
// Shared Layout - eliminates CSS duplication across all pages
import '@/styles/tokens.css'

interface Props {
  title: string;
  activePage: string;
}

const { title, activePage } = Astro.props;

const navItems = [
  { href: '/', icon: '▸', label: 'HORIZON', page: 'horizon' },
  { href: '/guild', icon: '▣', label: 'GUILD', page: 'guild' },
  { href: '/forge', icon: '⚙', label: 'FORGE', page: 'forge' },
  { href: '/void', icon: '▦', label: 'VOID', page: 'void' },
];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FOUNDRY // {title}</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="brand">
        <h1>FOUNDRY</h1>
        <div class="version">v1.1.0 // TERMINAL</div>
      </div>
      <nav class="nav">
        {navItems.map(item => (
          <a 
            href={item.href} 
            class={`nav-item ${activePage === item.page ? 'active' : ''}`}
          >
            <span class="nav-icon">{item.icon}</span>
            <span class="nav-label">{item.label}</span>
          </a>
        ))}
      </nav>
      <div class="sidebar-footer">
        <div>SYSTEM ONLINE</div>
        <div class="status-line">
          <span class="status-dot"></span>
          <span>MCP ACTIVE</span>
        </div>
      </div>
    </aside>
    <main class="main">
      <slot />
    </main>
  </div>
</body>
</html>
