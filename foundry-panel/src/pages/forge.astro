---
// src/pages/forge.astro - The Forge (Workflow Management)
import Layout from '../layouts/Layout.astro';
import { MCP_URL, FALLBACK_EXPERTS, FALLBACK_WORKFLOWS } from '../config';

let experts: any[] = FALLBACK_EXPERTS;
let workflows: any[] = FALLBACK_WORKFLOWS;
const url = Astro.url;
const selectedExpert = url.searchParams.get('expert');
const method = Astro.request.method;

if (method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action');
  
  if (action === 'create_workflow') {
    const expert_id = formData.get('expert_id');
    const name = formData.get('name');
    const description = formData.get('description');
    const prompt_template = formData.get('prompt_template');
    const input_type = formData.get('input_type');
    const output_type = formData.get('output_type');
    
    await fetch(`${MCP_URL}/workflows`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ expert_id, name, description, prompt_template, input_type, output_type })
    });
    return Astro.redirect('/forge');
  } else if (action === 'delete_workflow') {
    const workflow_id = formData.get('workflow_id');
    await fetch(`${MCP_URL}/workflows/${workflow_id}`, { method: 'DELETE' });
    return Astro.redirect('/forge');
  }
} else {
  try {
    const expRes = await fetch(`${MCP_URL}/experts`);
    if (expRes.ok) {
      const expData = await expRes.json();
      if (expData.results?.length) experts = expData.results;
    }
    
    const wfRes = await fetch(`${MCP_URL}/workflows${selectedExpert ? `?expert_id=${selectedExpert}` : ''}`);
    if (wfRes.ok) {
      const wfData = await wfRes.json();
      if (wfData.results?.length) workflows = wfData.results;
    }
  } catch (e) { console.error(e); }
}
---

<Layout title="FORGE" activePage="forge">
  <header class="header">
    <h2 class="header-title"><span>//</span> THE FORGE</h2>
    <button class="btn primary" onclick="toggleForm()">+ NEW BLUEPRINT</button>
  </header>
  
  <div class="filters">
    <a href="/forge" class={`filter-btn ${!selectedExpert ? 'active' : ''}`}>[ALL]</a>
    {experts.map((exp: any) => (
      <a href={`/forge?expert=${exp.slug}`} class={`filter-btn ${selectedExpert === exp.slug ? 'active' : ''}`}>{exp.name}</a>
    ))}
  </div>
  
  <div class="form-toggle">
    <div id="formPanel" class="form-panel">
      <div class="form-title">// NEW WORKFLOW BLUEPRINT</div>
      <form method="POST">
        <input type="hidden" name="_action" value="create_workflow"/>
        <div class="form-grid">
          <div class="form-group"><label>EXPERT</label><select name="expert_id" required><option value="">-- SELECT --</option>{experts.map((exp: any) => (<option value={exp.slug}>{exp.name}</option>))}</select></div>
          <div class="form-group"><label>NAME</label><input type="text" name="name" required placeholder="e.g. Code Review"/></div>
          <div class="form-group full"><label>DESCRIPTION</label><input type="text" name="description" placeholder="What this workflow does"/></div>
          <div class="form-group full"><label>PROMPT TEMPLATE</label><textarea name="prompt_template" required placeholder="Use {input} for user input..."></textarea></div>
          <div class="form-group"><label>INPUT TYPE</label><select name="input_type"><option value="text">text</option><option value="code">code</option><option value="audit">audit</option><option value="file">file</option></select></div>
          <div class="form-group"><label>OUTPUT TYPE</label><select name="output_type"><option value="code">code</option><option value="audit">audit</option><option value="brief">brief</option><option value="report">report</option></select></div>
          <div class="form-actions"><button type="submit" class="btn primary">CREATE</button><button type="button" class="btn" onclick="toggleForm()">CANCEL</button></div>
        </div>
      </form>
    </div>
  </div>
  
  <div class="workflow-grid">
    {workflows.map((wf: any) => (
      <article class="workflow">
        <div class="workflow-header">
          <div class="workflow-name">{wf.name}</div>
          <div class="workflow-badges"><span class="badge input">{wf.input_type}</span><span class="badge output">→ {wf.output_type}</span></div>
        </div>
        <div class="workflow-expert">ARCHITECT: {wf.expert_name}</div>
        <div class="workflow-desc">{wf.description || 'No description'}</div>
        <div class="workflow-prompt">{wf.prompt_template}</div>
        <div class="workflow-endpoint">/workflow/{wf.id}</div>
        <div class="workflow-actions">
          <form method="POST"><input type="hidden" name="_action" value="delete_workflow"/><input type="hidden" name="workflow_id" value={wf.id}/><button type="submit" class="btn danger">DELETE</button></form>
        </div>
      </article>
    ))}
  </div>
</Layout>

<script>function toggleForm() { document.getElementById('formPanel').classList.toggle('active'); }</script>
