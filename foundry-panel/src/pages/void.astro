---
// src/pages/void.astro - The Void (Admin/Settings)
import { MCP_URL } from '../config';

let health: any = null;
let stats = { experts: 0, workflows: 0 };


try {
  const healthRes = await fetch(`${MCP_URL}/health`);
  health = await healthRes.json();
  
  const expRes = await fetch(`${MCP_URL}/experts`);
  const expData = await expRes.json();
  stats.experts = (expData.results || []).length;
  
  const wfRes = await fetch(`${MCP_URL}/workflows`);
  const wfData = await wfRes.json();
  stats.workflows = (wfData.results || []).length;
} catch (e) { console.error(e); }
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FOUNDRY // VOID</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <style>
    :root { --bg: #12151a; --bg-card: #1a1f26; --terminal-green: #4ade80; --terminal-green-dim: rgba(74, 222, 128, 0.2); --text: #e2e8f0; --text-dim: #94a3b8; --text-bright: #f1f5f9; --border: #2d3748; --accent-amber: #fbbf24; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; }
    body { font-family: 'Share Tech Mono', 'JetBrains Mono', monospace; background: var(--bg); color: var(--text); font-size: 13px; line-height: 1.5; overflow: hidden; }
    body::before { content: ''; position: fixed; inset: 0; background: repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.1) 1px, transparent 1px, transparent 2px); pointer-events: none; z-index: 1000; }
    .layout { display: grid; grid-template-columns: 220px 1fr; height: 100vh; }
    .sidebar { background: var(--bg-card); border-right: 1px solid var(--border); padding: 1.5rem 1rem; display: flex; flex-direction: column; }
    .brand { padding-bottom: 1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .brand h1 { font-size: 1.25rem; font-weight: 400; color: var(--terminal-green); letter-spacing: 0.2em; }
    .brand .version { font-size: 0.65rem; color: var(--text-dim); margin-top: 0.25rem; }
    .nav { display: flex; flex-direction: column; gap: 0.25rem; }
    .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0.75rem; color: var(--text-dim); text-decoration: none; border: 1px solid transparent; transition: all 0.15s; }
    .nav-item:hover { color: var(--text-bright); background: var(--bg); }
    .nav-item.active { color: var(--terminal-green); background: rgba(74, 222, 128, 0.1); }
    .nav-icon { font-size: 0.9rem; opacity: 0.7; width: 16px; text-align: center; }
    .nav-label { font-size: 0.75rem; letter-spacing: 0.1em; }
    .sidebar-footer { margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.65rem; color: var(--text-dim); }
    .status-line { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; }
    .status-dot { width: 6px; height: 6px; background: var(--terminal-green); border-radius: 50%; animation: blink 2s infinite; }
    @keyframes blink { 0%, 50%, 100% { opacity: 1; } 25%, 75% { opacity: 0.3; } }
    .main { padding: 1.5rem 2rem; overflow-y: auto; }
    .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
    .header-title { font-size: 1rem; color: var(--accent-amber); letter-spacing: 0.15em; }
    .header-title span { color: var(--terminal-green); }
    
    .void-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 2rem; }
    .void-card { background: var(--bg-card); padding: 1.5rem; border: 1px solid var(--border); }
    .void-title { font-size: 0.75rem; letter-spacing: 0.15em; color: var(--accent-amber); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; }
    .void-title::before { content: '▦'; font-size: 0.9rem; }
    
    .stat-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--border); font-size: 0.75rem; }
    .stat-row:last-child { border-bottom: none; }
    .stat-key { color: var(--text-dim); }
    .stat-val { color: var(--terminal-green); font-family: 'JetBrains Mono', monospace; }
    .status-indicator { display: inline-flex; align-items: center; gap: 0.35rem; }
    .status-badge { padding: 0.15rem 0.4rem; font-size: 0.55rem; letter-spacing: 0.1em; }
    .status-badge.ok { background: #166534; color: #86efac; }
    .status-badge.error { background: #7f1d1d; color: #fca5a5; }
    
    .deploy-info { background: var(--bg); padding: 1rem; margin-top: 1rem; }
    .deploy-title { font-size: 0.7rem; color: var(--text-dim); margin-bottom: 0.75rem; letter-spacing: 0.1em; }
    .deploy-row { display: flex; justify-content: space-between; padding: 0.35rem 0; font-size: 0.7rem; border-bottom: 1px solid var(--border); }
    .deploy-row:last-child { border-bottom: none; }
    .deploy-key { color: var(--text-dim); }
    .deploy-val { color: var(--text); font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis; }
    
    .api-list { margin-top: 1rem; }
    .api-item { background: var(--bg); padding: 0.6rem 0.75rem; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; border: 1px solid var(--border); }
    .method { font-size: 0.6rem; font-weight: 500; padding: 0.15rem 0.35rem; letter-spacing: 0.05em; }
    .method.get { background: #166534; color: #86efac; }
    .method.post { background: #1e3a5f; color: #93c5fd; }
    .path { font-size: 0.75rem; color: var(--text); font-family: 'JetBrains Mono', monospace; }
    .desc { font-size: 0.65rem; color: var(--text-dim); margin-left: auto; }
    
    @media (max-width: 900px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: fixed; bottom: 0; left: 0; right: 0; flex-direction: row; padding: 0.75rem; border-right: none; border-top: 1px solid var(--border); z-index: 100; }
      .brand, .sidebar-footer { display: none; }
      .nav { flex-direction: row; gap: 0; }
      .nav-item { flex-direction: column; padding: 0.5rem; gap: 0.2rem; }
      .nav-label { font-size: 0.55rem; }
      .main { padding-bottom: 80px; }
      .void-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="brand"><h1>FOUNDRY</h1><div class="version">v1.1.0 // TERMINAL</div></div>
      <nav class="nav">
        <a href="/" class="nav-item"><span class="nav-icon">▸</span><span class="nav-label">HORIZON</span></a>
        <a href="/guild" class="nav-item"><span class="nav-icon">▣</span><span class="nav-label">GUILD</span></a>
        <a href="/forge" class="nav-item"><span class="nav-icon">⚙</span><span class="nav-label">FORGE</span></a>
        <a href="/void" class="nav-item active"><span class="nav-icon">▦</span><span class="nav-label">VOID</span></a>
      </nav>
      <div class="sidebar-footer"><div>SYSTEM ONLINE</div><div class="status-line"><span class="status-dot"></span><span>MCP ACTIVE</span></div></div>
    </aside>
    
    <main class="main">
      <header class="header">
        <h2 class="header-title"><span>//</span> THE VOID</h2>
      </header>
      
      <div class="void-grid">
        <div class="void-card">
          <div class="void-title">SYSTEM STATUS</div>
          <div class="stat-row"><span class="stat-key">SERVICE</span><span class="stat-val">{health?.service || 'N/A'}</span></div>
          <div class="stat-row"><span class="stat-key">VERSION</span><span class="stat-val">{health?.version || 'N/A'}</span></div>
          <div class="stat-row"><span class="stat-key">MODEL</span><span class="stat-val">{health?.model?.split('/').pop() || 'N/A'}</span></div>
          <div class="stat-row"><span class="stat-key">WORKERS AI</span><span class="stat-key"><span class="status-indicator"><span class={`status-badge ${health?.workers_ai === 'enabled' ? 'ok' : 'error'}`}>{health?.workers_ai?.toUpperCase() || 'N/A'}</span></span></span></div>
        </div>
        
        <div class="void-card">
          <div class="void-title">DATABASE</div>
          <div class="stat-row"><span class="stat-key">EXPERTS</span><span class="stat-val">{stats.experts}</span></div>
          <div class="stat-row"><span class="stat-key">WORKFLOWS</span><span class="stat-val">{stats.workflows}</span></div>
          <div class="stat-row"><span class="stat-key">DB NAME</span><span class="stat-val">foundry-db</span></div>
          <div class="stat-row"><span class="stat-key">PROVIDER</span><span class="stat-val">CLOUDFLARE D1</span></div>
        </div>
        
        <div class="void-card">
          <div class="void-title">DEPLOYMENT</div>
          <div class="deploy-info">
            <div class="deploy-title">MCP SERVER</div>
          <div class="deploy-row"><span class="deploy-key">URL</span><span class="deploy-val">{MCP_URL.replace('https://', '')}</span></div>
            <div class="deploy-row"><span class="deploy-key">STATUS</span><span class="status-indicator"><span class="status-badge ok">ONLINE</span></span></div>
          </div>
        </div>
        
        <div class="void-card">
          <div class="void-title">API REFERENCE</div>
          <div class="api-list">
            <div class="api-item"><span class="method get">GET</span><span class="path">/health</span><span class="desc">System health</span></div>
            <div class="api-item"><span class="method get">GET</span><span class="path">/experts</span><span class="desc">List experts</span></div>
            <div class="api-item"><span class="method post">POST</span><span class="path">/ai/:slug</span><span class="desc">AI completion</span></div>
            <div class="api-item"><span class="method post">POST</span><span class="path">/workflow/:id</span><span class="desc">Run workflow</span></div>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
