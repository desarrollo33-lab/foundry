---
// src/pages/void.astro - The Void (Admin/Settings)
import Layout from '../layouts/Layout.astro';
import { MCP_URL, FALLBACK_EXPERTS, FALLBACK_WORKFLOWS } from '../config';

let health: any = { service: 'foundry-mcp', version: '3.0.0', model: '@cf/zai-org/glm-4.7-flash', workers_ai: 'demo' };
let stats = { experts: 0, workflows: 0 };

try {
  const healthRes = await fetch(`${MCP_URL}/health`);
  if (healthRes.ok) {
    health = await healthRes.json();
  }
  
  const expRes = await fetch(`${MCP_URL}/experts`);
  if (expRes.ok) {
    const expData = await expRes.json();
    stats.experts = (expData.results || []).length;
  }
  
  const wfRes = await fetch(`${MCP_URL}/workflows`);
  if (wfRes.ok) {
    const wfData = await wfRes.json();
    stats.workflows = (wfData.results || []).length;
  }
  
  if (stats.experts === 0) stats.experts = FALLBACK_EXPERTS.length;
  if (stats.workflows === 0) stats.workflows = FALLBACK_WORKFLOWS.length;
} catch (e) { 
  console.error(e); 
  stats.experts = FALLBACK_EXPERTS.length;
  stats.workflows = FALLBACK_WORKFLOWS.length;
}
---

<Layout title="VOID" activePage="void">
  <header class="header2 class="header-title"><span>//</span>">
    <h THE VOID</h2>
  </header>
  
  <div class="void-grid">
    <div class="void-card">
      <div class="void-title">SYSTEM STATUS</div>
      <div class="stat-row"><span class="stat-key">SERVICE</span><span class="stat-val">{health?.service || 'N/A'}</span></div>
      <div class="stat-row"><span class="stat-key">VERSION</span><span class="stat-val">{health?.version || 'N/A'}</span></div>
      <div class="stat-row"><span class="stat-key">MODEL</span><span class="stat-val">{health?.model?.split('/').pop() || 'N/A'}</span></div>
      <div class="stat-row"><span class="stat-key">WORKERS AI</span><span class="stat-key"><span class="status-indicator"><span class={`status-badge ${health?.workers_ai === 'enabled' ? 'ok' : 'error'}`}>{health?.workers_ai?.toUpperCase() || 'N/A'}</span></span></span></div>
    </div>
    
    <div class="void-card">
      <div class="void-title">DATABASE</div>
      <div class="stat-row"><span class="stat-key">EXPERTS</span><span class="stat-val">{stats.experts}</span></div>
      <div class="stat-row"><span class="stat-key">WORKFLOWS</span><span class="stat-val">{stats.workflows}</span></div>
      <div class="stat-row"><span class="stat-key">DB NAME</span><span class="stat-val">foundry-db</span></div>
      <div class="stat-row"><span class="stat-key">PROVIDER</span><span class="stat-val">CLOUDFLARE D1</span></div>
    </div>
    
    <div class="void-card">
      <div class="void-title">DEPLOYMENT</div>
      <div class="deploy-info">
        <div class="deploy-title">MCP SERVER</div>
        <div class="deploy-row"><span class="deploy-key">URL</span><span class="deploy-val">{MCP_URL.replace('https://', '')}</span></div>
        <div class="deploy-row"><span class="deploy-key">STATUS</span><span class="status-indicator"><span class="status-badge ok">ONLINE</span></span></div>
      </div>
    </div>
    
    <div class="void-card">
      <div class="void-title">API REFERENCE</div>
      <div class="api-list">
        <div class="api-item"><span class="method get">GET</span><span class="path">/health</span><span class="desc">System health</span></div>
        <div class="api-item"><span class="method get">GET</span><span class="path">/experts</span><span class="desc">List experts</span></div>
        <div class="api-item"><span class="method post">POST</span><span class="path">/ai/:slug</span><span class="desc">AI completion</span></div>
        <div class="api-item"><span class="method post">POST</span><span class="path">/workflow/:id</span><span class="desc">Run workflow</span></div>
      </div>
    </div>
  </div>
</Layout>
