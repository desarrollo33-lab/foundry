---
// src/pages/index.astro - The Horizon (Dashboard)
import Layout from '../layouts/Layout.astro';
import { MCP_URL, FALLBACK_EXPERTS, FALLBACK_WORKFLOWS } from '../config';

let experts = FALLBACK_EXPERTS;
let workflows = FALLBACK_WORKFLOWS;
let projectsCount = 0;

try {
  const res = await fetch(`${MCP_URL}/experts`);
  if (res.ok) { const data = await res.json(); if (data.results?.length) experts = data.results; }
  const wfRes = await fetch(`${MCP_URL}/workflows`);
  if (wfRes.ok) { const wfData = await wfRes.json(); if (wfData.results?.length) workflows = wfData.results; }
  try {
    const projRes = await fetch(`${MCP_URL}/api/v1/projects`);
    if (projRes.ok) { const projData = await projRes.json(); projectsCount = projData.results?.length || 0; }
  } catch { /* ignore */ }
} catch (e) { console.error('Failed to fetch dashboard data:', e); }
---
<Layout title="TERMINAL" activePage="horizon">
  <header class="header">
    <h2 class="header-title"><span>//</span> THE HORIZON</h2>
    <div class="header-meta">{new Date().toISOString().slice(0,19).replace('T', ' ')} UTC</div>
  </header>
  
  <div class="stats" style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem;">
    <div class="stat" style="background:var(--bg-card);padding:1rem;border:1px solid var(--border)"><div class="stat-value" style="font-size:1.5rem;color:var(--terminal-green)">{experts.length}</div><div class="stat-label" style="font-size:0.65rem;color:var(--text-dim);letter-spacing:0.15em;margin-top:0.25rem">ARCHITECTS</div></div>
    <div class="stat" style="background:var(--bg-card);padding:1rem;border:1px solid var(--border)"><div class="stat-value" style="font-size:1.5rem;color:var(--terminal-green)">{workflows?.length || 0}</div><div class="stat-label" style="font-size:0.65rem;color:var(--text-dim);letter-spacing:0.15em;margin-top:0.25rem">BLUEPRINTS</div></div>
    <div class="stat" style="background:var(--bg-card);padding:1rem;border:1px solid var(--border)"><div class="stat-value" style="font-size:1.5rem;color:var(--terminal-green)">{projectsCount}</div><div class="stat-label" style="font-size:0.65rem;color:var(--text-dim);letter-spacing:0.15em;margin-top:0.25rem">PROJECTS</div></div>
    <div class="stat" style="background:var(--bg-card);padding:1rem;border:1px solid var(--border)"><div class="stat-value" style="font-size:1.5rem;color:#60a5fa">OK</div><div class="stat-label" style="font-size:0.65rem;color:var(--text-dim);letter-spacing:0.15em;margin-top:0.25rem">STATUS</div></div>
  </div>
  
  <section class="section">
    <div class="section-header"><span class="section-title">// THE GUILD</span><span class="section-count">[{experts.length}]</span></div>
    <div class="expert-grid">
      {experts.map((expert: any) => (
        <article class="expert">
          <div class="expert-header">
            <div class="expert-avatar" style={`color:${expert.color};border-color:${expert.color}80`}>
              <img src={`/images/${expert.slug}.jpg`} alt={expert.name} onerror="this.style.display='none';this.parentElement.textContent=this.parentElement.textContent.trim()" />
              {expert.name.charAt(0)}
            </div>
            <div class="expert-info"><div class="expert-name">{expert.name}</div><div class="expert-title">{expert.title}</div></div>
          </div>
          <div class="expert-philosophy">"{expert.philosophy}"</div>
          <div class="expert-endpoint">/ai/{expert.slug}</div>
          <div class="expert-actions"><a href="/guild" class="btn">VIEW</a><a href={`/forge?expert=${expert.slug}`} class="btn">WFS</a></div>
        </article>
      ))}
    </div>
  </section>
  
  <section class="section">
    <div class="section-header"><span class="section-title">// ENDPOINTS</span><span class="section-count">[6]</span></div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.75rem">
      <div style="background:var(--bg-card);padding:0.6rem 0.75rem;border:1px solid var(--border);display:flex;align-items:center;gap:0.5rem"><span style="font-size:0.6rem;font-weight:500;padding:0.15rem 0.35rem;background:#166534;color:#86efac">GET</span><span style="font-size:0.7rem;font-family:'JetBrains Mono'">/experts</span></div>
      <div style="background:var(--bg-card);padding:0.6rem 0.75rem;border:1px solid var(--border);display:flex;align-items:center;gap:0.5rem"><span style="font-size:0.6rem;font-weight:500;padding:0.15rem 0.35rem;background:#166534;color:#86efac">GET</span><span style="font-size:0.7rem;font-family:'JetBrains Mono'">/experts/:slug</span></div>
      <div style="background:var(--bg-card);padding:0.6rem 0.75rem;border:1px solid var(--border);display:flex;align-items:center;gap:0.5rem"><span style="font-size:0.6rem;font-weight:500;padding:0.15rem 0.35rem;background:#1e40af;color:#93c5fd">POST</span><span style="font-size:0.7rem;font-family:'JetBrains Mono'">/ai/:expert</span></div>
      <div style="background:var(--bg-card);padding:0.6rem 0.75rem;border:1px solid var(--border);display:flex;align-items:center;gap:0.5rem"><span style="font-size:0.6rem;font-weight:500;padding:0.15rem 0.35rem;background:#1e40af;color:#93c5fd">POST</span><span style="font-size:0.7rem;font-family:'JetBrains Mono'">/workflow/:id</span></div>
      <div style="background:var(--bg-card);padding:0.6rem 0.75rem;border:1px solid var(--border);display:flex;align-items:center;gap:0.5rem"><span style="font-size:0.6rem;font-weight:500;padding:0.15rem 0.35rem;background:#166534;color:#86efac">GET</span><span style="font-size:0.7rem;font-family:'JetBrains Mono'">/workflows</span></div>
      <div style="background:var(--bg-card);padding:0.6rem 0.75rem;border:1px solid var(--border);display:flex;align-items:center;gap:0.5rem"><span style="font-size:0.6rem;font-weight:500;padding:0.15rem 0.35rem;background:#166534;color:#86efac">GET</span><span style="font-size:0.7rem;font-family:'JetBrains Mono'">/health</span></div>
    </div>
  </section>
</Layout>
