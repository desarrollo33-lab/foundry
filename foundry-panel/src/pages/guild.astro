---
// src/pages/guild.astro - The Guild (Expert Management)
import Layout from '../layouts/Layout.astro';
import { MCP_URL, FALLBACK_EXPERTS } from '../config';

let experts: any[] = FALLBACK_EXPERTS;
const method = Astro.request.method;

if (method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action');
  
  if (action === 'create_expert') {
    const name = formData.get('name');
    const slug = formData.get('slug');
    const title = formData.get('title');
    const philosophy = formData.get('philosophy');
    const color = formData.get('color');
    
    await fetch(`${MCP_URL}/experts`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, slug, title, philosophy, color })
    });
    return Astro.redirect('/guild');
  } else if (action === 'delete_expert') {
    const expert_id = formData.get('expert_id');
    await fetch(`${MCP_URL}/experts/${expert_id}`, { method: 'DELETE' });
    return Astro.redirect('/guild');
  }
} else {
  try {
    const res = await fetch(`${MCP_URL}/experts`);
    if (res.ok) {
      const data = await res.json();
      if (data.results?.length) experts = data.results;
    }
  } catch (e) { console.error(e); }
}
---

<Layout title="GUILD" activePage="guild">
  <header class="header">
    <h2 class="header-title"><span>//</span> THE GUILD</h2>
    <button class="btn primary" onclick="toggleForm()">+ NEW ARCHITECT</button>
  </header>
  
  <div class="form-toggle">
    <div id="formPanel" class="form-panel">
      <div class="form-title">// NEW ARCHITECT</div>
      <form method="POST">
        <input type="hidden" name="_action" value="create_expert"/>
        <div class="form-grid">
          <div class="form-group"><label>NAME</label><input type="text" name="name" required placeholder="e.g. Nikola Tesla"/></div>
          <div class="form-group"><label>SLUG</label><input type="text" name="slug" required placeholder="e.g. nikola-tesla"/></div>
          <div class="form-group"><label>TITLE</label><input type="text" name="title" required placeholder="e.g. Physics Expert"/></div>
          <div class="form-group"><label>COLOR</label><input type="text" name="color" placeholder="#FF6B35"/></div>
          <div class="form-group full"><label>PHILOSOPHY</label><input type="text" name="philosophy" placeholder="Short quote"/></div>
          <div class="form-actions"><button type="submit" class="btn primary">CREATE</button><button type="button" class="btn" onclick="toggleForm()">CANCEL</button></div>
        </div>
      </form>
    </div>
  </div>
  
  <section class="section">
    <div class="section-header"><span class="section-title">// ARCHITECTS</span><span class="section-count">[{experts.length}]</span></div>
    <div class="expert-grid">
      {experts.map((expert: any) => (
        <article class="expert">
          <div class="expert-header">
            <div class="expert-avatar" style={`color:${expert.color};border-color:${expert.color}80`}>
              <img src={`/images/${expert.slug}.jpg`} alt={expert.name} onerror="this.style.display='none';this.parentElement.textContent=this.parentElement.textContent.trim()" />
              {expert.name.charAt(0)}
            </div>
            <div class="expert-info">
              <div class="expert-name">{expert.name}</div>
              <div class="expert-title">{expert.title}</div>
              <code class="expert-slug">/ai/{expert.slug}</code>
            </div>
          </div>
          <div class="expert-details"><strong>Philosophy:</strong> {expert.philosophy || 'N/A'}</div>
          <div class="expert-actions">
            <a href={`/forge?expert=${expert.slug}`} class="btn">WFS</a>
            <form method="POST" style="flex:1"><input type="hidden" name="_action" value="delete_expert"/><input type="hidden" name="expert_id" value={expert.slug}><button type="submit" class="btn danger" style="width:100%">DELETE</button></form>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<script>function toggleForm() { document.getElementById('formPanel').classList.toggle('active'); }</script>
